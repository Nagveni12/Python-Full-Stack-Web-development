def print_name(name, n):
    if n == 0:      # base condition
        return
    print(name)
    print_name(name, n-1)   # recursive call

# user input
name = input("Enter name: ")
times = int(input("How many times: "))

print_name(name, times)

3.
def sum_n(n):
    if n == 1:           # base condition
        return 1
    else:
        return n + sum_n(n-1)   # recursive call

# input
n = int(input("Enter n: "))

result = sum_n(n)
print("Sum:", result)
