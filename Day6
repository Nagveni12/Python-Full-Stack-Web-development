def student_result():
    n = int(input("Enter number of students: "))

    for i in range(n):
        marks = float(input(f"Enter marks for student {i+1}: "))

        if marks > 90:
            result = "A"
        elif marks > 75:
            result = "B"
        elif marks > 50:
            result = "C"
        elif marks > 35:
            result = "Pass"
        else:
            result = "Fail"

        print(f"Student {i+1} Result: {result}")

student_result()

