def numbers(n):
    for i in range(1, n+1):
        yield i

for num in numbers(5):
    print(num)

2.
def book_seats(total):
    for seat in range(1, total+1):
        yield f"Seat {seat} booked"

booking = book_seats(3)

print(next(booking))
print(next(booking))
print(next(booking))

3.
def my_decorator(func):
    def wrapper(name):
        print("Before function")
        func(name)
        print("After function")
    return wrapper

@my_decorator
def greet(name):
    print("Hello", name)

greet("Megha")
