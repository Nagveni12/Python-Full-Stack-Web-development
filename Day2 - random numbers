import random

def simple_word_guessing_game():
    words = ["apple", "banana", "cherry", "orange", "grape", "mango"]
    secret_word = random.choice(words)
    attempts = 0

    print("Guess the fruit!")
    print(f"Hint: It has {len(secret_word)} letters.")

    while True:
        guess = input("Enter your guess: ").lower()
        attempts += 1

        if guess < secret_word:
            print("Your word comes alphabetically BEFORE the secret word.")
        elif guess > secret_word:
            print("Your word comes alphabetically AFTER the secret word.")
        else:
            print(f"Yay! You guessed '{secret_word}' in {attempts} attempts!")
            break

        # Additional hint
        if len(guess) != len(secret_word):
            print(f"Hint: The word has {len(secret_word)} letters.")

# Start the game
simple_word_guessing_game()

