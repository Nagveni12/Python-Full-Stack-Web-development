import random

def word_guessing_game():
    words = ["apple", "banana", "cherry", "date", "fig", "grape", "kiwi", "lemon", "mango", "orange"]

    secret_word = random.choice(words)
    attempts = 0

    print("Guess a word from this list:", words)
    print("Clue: Words are in alphabetical order. Try to find the secret word!")

    while True:
        guess = input("Enter your guess: ").lower()
        attempts += 1

        if guess < secret_word:
            print(f"'{guess}' comes BEFORE '{secret_word}' alphabetically!")
        elif guess > secret_word:
            print(f"'{guess}' comes AFTER '{secret_word}' alphabetically!")
        else:
            print(f"Yay! You guessed '{secret_word}' in {attempts} attempts!")
            break


word_guessing_game()
