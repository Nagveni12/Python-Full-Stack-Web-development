# Base class
class Notification:
    def send_notification(self):
        print("Sending notification...")

# Instagram class
class Instagram(Notification):
    def send_notification(self):
        print("New notification from Instagram")

# WhatsApp class
class WhatsApp(Notification):
    def send_notification(self):
        print("New notification from WhatsApp")

# Email class
class Email(Notification):
    def send_notification(self):
        print("New Email received")

# Polymorphism
def notify_user(app):
    app.send_notification()

# objects
insta = Instagram()
whatsapp = WhatsApp()
email = Email()

# calling same function for different objects
notify_user(insta)
notify_user(whatsapp)
notify_user(email)

