def calculate_simple_interest():
    p = float(input("Enter principal: "))
    r = float(input("Enter rate (%): "))
    t = float(input("Enter time (years): "))

    si = (p * r * t) / 100

    print("Simple Interest:", si)

calculate_simple_interest()
